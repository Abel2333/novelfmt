BasedOnStyle: LLVM
IndentWidth: 4
TabWidth: 4
UseTab: Never
ContinuationIndentWidth: 4
ColumnLimit: 100
Standard: Latest
PointerAlignment: Left
SortIncludes: CaseSensitive
IncludeBlocks: Regroup
IncludeCategories:
    - Regex: '^<([[:alnum:]_]+)>$'
      Priority: 1
    - Regex: '^".*"'
      Priority: 2
    - Regex: '^<.*>$'
      Priority: 3
